@page
@model Todo.UI.Pages.Account.RegisterModel
@{ Layout = null; }
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Create Account — ICA TaskFlow</title>
    <link rel="stylesheet"
          href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
          integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH"
          crossorigin="anonymous" />
    <link rel="stylesheet"
          href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css"
          integrity="sha384-tViUnnbYAV00FLIhhi3v/dWt3Jxw4gZQcNoSCxCIFNJVCx7/D55/wXsrNIRANwdD"
          crossorigin="anonymous" />
    <link rel="stylesheet" href="~/css/site.css" />
    <script>(function(){var t=localStorage.getItem('ica_theme')||'light';document.documentElement.setAttribute('data-bs-theme',t);})();</script>
</head>
<body>
<div class="auth-page">
    <div class="auth-container">

        <div class="auth-logo">
            <div class="auth-logo-icon"><i class="bi bi-check2-square"></i></div>
            <div class="auth-logo-title">ICA TaskFlow</div>
            <div class="auth-logo-sub">Employee Task Management Portal</div>
        </div>

        <div class="auth-card">
            <div class="auth-card-title">Create your account</div>
            <div class="auth-card-sub">Join ICA TaskFlow to manage your tasks</div>

            <div id="alertBox" class="alert d-none mb-3" role="alert"></div>

            <form id="regForm" novalidate>
                <div class="mb-3">
                    <label class="form-label">Full Name</label>
                    <input type="text" id="username" class="form-control" placeholder="John Smith" autocomplete="name" />
                    <div class="invalid-feedback">Name must be at least 2 characters.</div>
                </div>
                <div class="mb-3">
                    <label class="form-label">Email address</label>
                    <input type="email" id="email" class="form-control" placeholder="you@@ica.com" autocomplete="email" />
                    <div class="invalid-feedback">Please enter a valid email.</div>
                </div>
                <div class="mb-3">
                    <label class="form-label">Password</label>
                    <input type="password" id="password" class="form-control" placeholder="Min. 8 chars, upper, lower, digit, symbol" autocomplete="new-password" />
                    <div class="invalid-feedback">Password must be 8+ chars with uppercase, lowercase, digit, and symbol.</div>
                </div>
                <div class="mb-4">
                    <label class="form-label">Confirm Password</label>
                    <input type="password" id="confirmPassword" class="form-control" placeholder="Repeat your password" autocomplete="new-password" />
                    <div class="invalid-feedback">Passwords do not match.</div>
                </div>
                <button type="submit" id="submitBtn" class="btn-auth">
                    <span id="btnText">Create Account</span>
                    <span id="btnSpinner" class="spinner-border spinner-border-sm d-none" role="status"></span>
                </button>
            </form>

            <div class="auth-divider">or</div>
            <div class="auth-footer">
                Already have an account? <a href="/Account/Login">Sign in</a>
            </div>
        </div>
    </div>
</div>

<script>
    // H3: API base from server config
    const API_BASE = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.ApiBase));

    var pwPattern = /^(?=.*[A-Z])(?=.*[a-z])(?=.*\d)(?=.*[^A-Za-z0-9]).{8,}$/;

    document.getElementById('regForm').addEventListener('submit', async function(e) {
        e.preventDefault();
        var username        = document.getElementById('username').value.trim();
        var email           = document.getElementById('email').value.trim();
        var password        = document.getElementById('password').value;
        var confirmPassword = document.getElementById('confirmPassword').value;

        clearErrors();

        var valid = true;
        if (username.length < 2)            { markInvalid('username');        valid = false; }
        if (!email || !email.includes('@@')) { markInvalid('email');           valid = false; }
        if (!pwPattern.test(password))      { markInvalid('password');         valid = false; }
        if (password !== confirmPassword)   { markInvalid('confirmPassword');  valid = false; }
        if (!valid) return;

        setLoading(true);
        try {
            var res  = await fetch(API_BASE + '/auth/register', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ username, email, password, confirmPassword })
            });
            var data = await res.json();
            if (data.success) {
                showAlert('Account created! Redirecting to login…', 'success');
                setTimeout(function() { window.location.href = '/Account/Login'; }, 1400);
            } else {
                showAlert(data.message || 'Registration failed. Please try again.', 'danger');
            }
        } catch (err) {
            showAlert('Unable to connect to the server.', 'danger');
        } finally {
            setLoading(false);
        }
    });

    function markInvalid(id) { document.getElementById(id).classList.add('is-invalid'); }

    function clearErrors() {
        ['username','email','password','confirmPassword'].forEach(function(id) {
            document.getElementById(id).classList.remove('is-invalid');
        });
        document.getElementById('alertBox').classList.add('d-none');
    }

    function showAlert(msg, type) {
        var box = document.getElementById('alertBox');
        box.className = 'alert alert-' + type + ' mb-3';
        box.textContent = msg;
    }

    function setLoading(on) {
        document.getElementById('submitBtn').disabled = on;
        document.getElementById('btnText').textContent = on ? 'Creating account…' : 'Create Account';
        document.getElementById('btnSpinner').classList.toggle('d-none', !on);
    }
</script>
</body>
</html>
