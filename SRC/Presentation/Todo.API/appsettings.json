{
  "ConnectionStrings": {
    "DefaultConnection": "Server=YOUR_SERVER;Database=ICATodoApp;User Id=YOUR_USER;Password=YOUR_PASSWORD;TrustServerCertificate=True;"
  },
  "JwtSettings": {
